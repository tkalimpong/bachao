rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    /** Owner bootstrap: groupId equals the creator's uid. */
    function isGroupOwner(groupId) {
      return signedIn() && request.auth.uid == groupId;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.groupId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /groups/{groupId} {
      // Owner must read their group before the member doc exists (first sign-in).
      allow read: if isMember(groupId) || isGroupOwner(groupId);
      allow create: if isGroupOwner(groupId);

      match /members/{memberId} {
        allow read: if isMember(groupId)
          || (signedIn() && request.auth.uid == memberId);
        allow create: if signedIn() && request.auth.uid == memberId;
        allow update, delete: if isMember(groupId);
      }

      match /expenses/{docId} {
        allow read, write: if isMember(groupId);
      }
      match /incomes/{docId} {
        allow read, write: if isMember(groupId);
      }
      match /transfers/{docId} {
        allow read, write: if isMember(groupId);
      }
      match /categoryBudgets/{docId} {
        allow read, write: if isMember(groupId);
      }
      match /envelopes/{docId} {
        allow read, write: if isMember(groupId);
      }
      match /settings/{docId} {
        allow read, write: if isMember(groupId);
      }
    }
  }
}
